# Copy this file to .env and fill in your values
# Never commit .env to git

PORT=3000

# SMTP settings (works with Gmail, Outlook, any provider)
# For Gmail: enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where form submissions get delivered
MAIL_TO=info@lanzaroteproducciones.com
MAIL_FROM="Onyxay Lanzarote Producciones <noreply@lanzaroteproducciones.com>"

# Allowed origin for CORS (your domain in production)
ALLOWED_ORIGIN=http://localhost:3000
